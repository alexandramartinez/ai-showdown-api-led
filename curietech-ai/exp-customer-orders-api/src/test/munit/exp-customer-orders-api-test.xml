    <munit:config name="exp-customer-orders-api-test.xml"/>

    <munit:test name="get-customers-test" description="GET /customers returns customer list from customer process API">
        <munit:behavior>
            <munit-tools:mock-when processor="http:request" doc:name="Mock Get Customers">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Call Customer Process API - Get Customers"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[MunitTools::getResourceAsString('fixtures/customer-list.json')]" mediaType="application/json" encoding="UTF-8"/>
                    <munit-tools:attributes value="#[{statusCode: 200, reasonPhrase: 'OK', headers: {'content-type': 'application/json'}}]"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <munit:execution>
            <munit:set-event doc:name="Set GET Customers Event">
                <munit:attributes value="#[{uriParams: {}, headers: {'x-correlation-id': 'test-correlation-id'}}]"/>
            </munit:set-event>
            <flow-ref name="get:\customers:exp-customer-orders-api-config"/>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that expression="#[payload]" is="#[MunitTools::equalTo(read(MunitTools::getResourceAsString('fixtures/customer-list.json'), 'application/json'))]"/>
            <munit-tools:assert-that expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(200)]"/>
            <munit-tools:verify-call processor="http:request" times="1" doc:name="Verify Get Customers Call">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Call Customer Process API - Get Customers"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>


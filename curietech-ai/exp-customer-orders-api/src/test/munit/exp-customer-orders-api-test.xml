    <munit:test name="delete-customer-conflict-test" description="DELETE /customers/{customerId} propagates downstream 409 conflict body">
        <munit:behavior>
            <munit-tools:mock-when processor="http:request" doc:name="Mock Delete Customer Conflict">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Call Customer Process API - Delete Customer"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[MunitTools::getResourceAsString('fixtures/customer-delete-conflict.json')]" mediaType="application/json" encoding="UTF-8"/>
                    <munit-tools:attributes value="#[{statusCode: 409, reasonPhrase: 'Conflict', headers: {'content-type': 'application/json'}}]"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <munit:execution>
            <munit:set-event doc:name="Set DELETE Customer Event">
                <munit:attributes value="#[{uriParams: {customerId: 'CUST-10421'}, headers: {'x-correlation-id': 'test-correlation-id'}}]"/>
            </munit:set-event>
            <flow-ref name="delete:\customers\(customerId):exp-customer-orders-api-config"/>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that expression="#[payload.error]" is="#[MunitTools::equalTo('CONFLICT')]"/>
            <munit-tools:assert-that expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(409)]"/>
            <munit-tools:verify-call processor="http:request" times="1" doc:name="Verify Delete Customer Call">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Call Customer Process API - Delete Customer"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>


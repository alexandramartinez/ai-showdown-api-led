        <http:request method="PUT" config-ref="processHttpRequestConfig" url="#[p('prc.order.baseUrl') ++ '/orders/' ++ attributes.uriParams.'orderId']" sendCorrelationId="ALWAYS" correlationId="#[vars.clientCorrelationId default correlationId]" doc:name="Call Order Process API - Update Order">

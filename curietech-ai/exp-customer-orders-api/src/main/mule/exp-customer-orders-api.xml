    <flow name="delete:\customers\(customerId)\orders\(orderId):exp-customer-orders-api-config">
        <http:request method="DELETE" config-ref="processHttpRequestConfig" url="#[p('prc.order.baseUrl') ++ '/orders/' ++ attributes.uriParams.'orderId']" sendCorrelationId="ALWAYS" correlationId="#[vars.clientCorrelationId default correlationId]" doc:name="Call Order Process API - Delete Order">
            <http:headers><![CDATA[#[{"x-correlation-id": vars.clientCorrelationId default correlationId, "accept": "application/json"}]]]></http:headers>

            <http:body><![CDATA[#[payload]]]></http:body>
            <http:headers><![CDATA[#[{"x-correlation-id": vars.clientCorrelationId default correlationId, "content-type": "application/json", "accept": "application/json"}]]]></http:headers>
            <http:response-validator>
                <http:success-status-code-validator values="0..599"/>
            </http:response-validator>
        </http:request>
        <set-variable variableName="httpStatus" value="#[attributes.statusCode default 200]" doc:name="Set Response Status"/>

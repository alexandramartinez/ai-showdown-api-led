#%RAML 1.0 DataType
type: object
properties:
  id: string
  customerId: string
  status:
    type: string
    enum: [NEW, PAID, SHIPPED, CANCELLED]
  total: number
  currency: string
  items:
    type: array
    items:
      type: object
      properties:
        sku: string
        name: string
        qty: integer
        price: number
  createdAt: datetime

#%RAML 1.0
title: Experience API - Customers & Orders (Web/Mobile)
version: v1
baseUri: http://localhost:8081/api
mediaType: application/json

documentation:
  - title: Overview
    content: |
      Channel-tailored API for web/mobile clients. It mirrors the customer-centric
      resource tree of the Process API 1:1 for all 11 operations, and adds channel
      value-add on GET /customers/{customerId}: a single call returns the customer
      profile WITH their orders embedded (one round trip for a mobile detail screen).

types:
  Customer: !include dataTypes/Customer.raml
  CustomerWithOrders: !include dataTypes/CustomerWithOrders.raml
  NewCustomer: !include dataTypes/NewCustomer.raml
  Order: !include dataTypes/Order.raml
  NewOrder: !include dataTypes/NewOrder.raml
  Error: !include dataTypes/Error.raml

/customers:
  get:
    description: List all customers.
    responses:
      200:
        body: { application/json: { type: Customer[] } }
  post:
    description: Create a new customer.
    body: { application/json: { type: NewCustomer } }
    responses:
      201:
        body: { application/json: { type: Customer } }
      400:
        body: { application/json: { type: Error } }
  /{customerId}:
    uriParameters:
      customerId: string
    get:
      description: >
        Get one customer AGGREGATED with their orders (channel value-add:
        one call for a mobile detail screen).
      responses:
        200:
          body: { application/json: { type: CustomerWithOrders } }
        404:
          body: { application/json: { type: Error } }
    put:
      description: Edit an existing customer's details.
      body: { application/json: { type: NewCustomer } }
      responses:
        200:
          body: { application/json: { type: Customer } }
        404:
          body: { application/json: { type: Error } }
    delete:
      description: Delete a customer only if it has no orders attached (409 otherwise).
      responses:
        204:
        404:
          body: { application/json: { type: Error } }
        409:
          body: { application/json: { type: Error } }
    /orders:
      get:
        description: List a customer's orders.
        responses:
          200:
            body: { application/json: { type: Order[] } }
          404:
            body: { application/json: { type: Error } }
      post:
        description: Create a new order attached to this customer.
        body: { application/json: { type: NewOrder } }
        responses:
          201:
            body: { application/json: { type: Order } }
          404:
            body: { application/json: { type: Error } }
      /{orderId}:
        uriParameters:
          orderId: string
        get:
          description: Get one of the customer's order's details.
          responses:
            200:
              body: { application/json: { type: Order } }
            404:
              body: { application/json: { type: Error } }
        put:
          description: Edit an existing order (stays attached to the customer).
          body: { application/json: { type: NewOrder } }
          responses:
            200:
              body: { application/json: { type: Order } }
            404:
              body: { application/json: { type: Error } }
        delete:
          description: Delete an existing order.
          responses:
            204:
            404:
              body: { application/json: { type: Error } }
        /cancel:
          post:
            description: Cancel an existing order (status=CANCELLED; not deleted).
            responses:
              200:
                body: { application/json: { type: Order } }
              404:
                body: { application/json: { type: Error } }

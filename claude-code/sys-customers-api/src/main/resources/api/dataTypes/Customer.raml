#%RAML 1.0 DataType
type: object
description: A customer record as stored by the system of record.
properties:
  id:
    type: string
    description: Unique customer identifier (UUID), assigned by the system.
  firstName: string
  lastName: string
  email:
    type: string
    pattern: "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
  phone:
    type: string
    required: false
  createdAt:
    type: datetime
    description: RFC-3339 timestamp when the record was created.

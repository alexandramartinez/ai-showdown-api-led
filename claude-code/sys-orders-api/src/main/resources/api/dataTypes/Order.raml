#%RAML 1.0 DataType
type: object
description: An order record. Always attached to a customer via customerId.
properties:
  id:
    type: string
    description: Unique order identifier (UUID), assigned by the system.
  customerId:
    type: string
    description: FK to the owning customer.
  status:
    type: string
    enum: [NEW, PAID, SHIPPED, CANCELLED]
  total: number
  currency:
    type: string
    default: USD
  items:
    type: array
    items:
      type: object
      properties:
        sku: string
        name: string
        qty: integer
        price: number
  createdAt:
    type: datetime

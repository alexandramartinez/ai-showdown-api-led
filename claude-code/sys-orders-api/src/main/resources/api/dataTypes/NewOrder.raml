#%RAML 1.0 DataType
type: object
description: >
  Payload for creating or editing an order. Server owns id and createdAt.
  status is optional on create (defaults to NEW).
properties:
  customerId: string
  status:
    type: string
    enum: [NEW, PAID, SHIPPED, CANCELLED]
    required: false
  currency:
    type: string
    required: false
  items:
    type: array
    items:
      type: object
      properties:
        sku: string
        name: string
        qty: integer
        price: number
additionalProperties: false

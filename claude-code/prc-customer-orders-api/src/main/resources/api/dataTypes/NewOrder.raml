#%RAML 1.0 DataType
type: object
description: >
  Order create/edit payload at the process layer. customerId is NOT required here:
  the process stamps it from the {customerId} URI parameter.
properties:
  status:
    type: string
    enum: [NEW, PAID, SHIPPED, CANCELLED]
    required: false
  currency:
    type: string
    required: false
  items:
    type: array
    items:
      type: object
      properties:
        sku: string
        name: string
        qty: integer
        price: number
additionalProperties: false
